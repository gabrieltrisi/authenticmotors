# ------------------------------------------------------------------
# Variáveis de ambiente — Authentic Motors
# Copie este arquivo para `.env.local` e preencha os valores.
# Na Vercel: Project → Settings → Environment Variables.
# ------------------------------------------------------------------

# Webhook do n8n que recebe os agendamentos (POST JSON).
# Por ser NEXT_PUBLIC_, é embutida no bundle do cliente (não é segredo).
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://gabrieltrisi.app.n8n.cloud/webhook/authentic-motors-agendamento

# Endpoint do n8n que retorna os horários disponíveis/ocupados de uma data (POST JSON).
NEXT_PUBLIC_N8N_HORARIOS_URL=https://gabrieltrisi.app.n8n.cloud/webhook/authentic-motors-horarios-disponiveis

# Endpoint do n8n que LISTA os agendamentos para o painel /admin/agendamentos (GET JSON).
# Quando vazio, o painel exibe dados de exemplo (mock).
NEXT_PUBLIC_ADMIN_API_URL=

# Senha de acesso ao painel /admin/agendamentos (proteção simples client-side, temporária).
# Quando vazia, o acesso é bloqueado. NÃO é segurança forte (fica visível no bundle).
NEXT_PUBLIC_ADMIN_PASSWORD=

# Banco PostgreSQL (Neon) — módulo de Caixa (/admin/caixa). Segredo de SERVIDOR
# (sem prefixo NEXT_PUBLIC_). Use a connection string pooled com ?sslmode=require.
# O valor real fica no .env.local (não versionado) e na Vercel (Environment Variables).
DATABASE_URL=

# ------------------------------------------------------------------
# E-mail transacional (Resend) — notificações de agendamento.
# Se RESEND_API_KEY ou EMAIL_FROM estiverem vazios, o envio é DESATIVADO
# (sem erro): o fluxo continua e apenas registra "email disabled" no log.
# ------------------------------------------------------------------
RESEND_API_KEY=
# Remetente. Ex.: "Authentic Motors <agendamentos@seudominio.com>".
# IMPORTANTE: em produção o domínio do EMAIL_FROM precisa estar VALIDADO no
# Resend (Domains → Add Domain → registros DNS). Sem domínio validado, só é
# possível enviar para o e-mail da própria conta Resend (modo de teste).
EMAIL_FROM=
# (Opcional) Destinatário de fallback p/ notificações da oficina quando o
# agendamento não tiver e-mail do cliente. Ex.: contato@seudominio.com
EMAIL_TO=
